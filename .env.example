# Module 1 browser voice agent. Agent IDs are public identifiers, not API secrets.
VITE_ELEVENLABS_INTAKE_AGENT_ID=

# Server-side key used for simulations and conversation retrieval.
ELEVENLABS_API_KEY=

# Module 3 venue-calling agent. Required for AI simulation and browser voice.
ELEVENLABS_AGENT_ID=

# Required only for real phone calls.
ELEVENLABS_PHONE_NUMBER_ID=

# Module 2 Google discovery. Not needed for Mock or imported Module 2 JSON.
GOOGLE_MAPS_API_KEY=

# Optional Module 1 validation assistance. Deterministic validation is used without these.
OPEN_AI_API_KEY=
OPEN_AI_MODEL=

# Optional: your own authorised test number for the cooperative fictional mock venue.
MOCK_TEST_PHONE=
